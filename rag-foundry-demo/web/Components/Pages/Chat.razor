@page "/"
@rendermode InteractiveServer
@inject RagChatService Rag
@inject IJSRuntime JS

<PageTitle>Mining Assistant — RAG on Azure AI Foundry</PageTitle>

<div class="app">
    <div class="app-header">
        <h1>Mining Operations <span class="amber">Assistant</span>
            <span class="pill">RAG · Azure AI Foundry</span>
            <a class="pill pill-link" href="slides.html" target="_blank" rel="noopener">📊 Slides</a></h1>
        <div class="sub">Grounded answers from the site knowledge base, with citations.
            Ask about PPE, equipment maintenance, shift handover, or incident reporting.</div>
    </div>

    <div class="messages" id="messages">
        @if (_messages.Count == 0)
        {
            <div class="hint">
                Try: <code>What PPE is required on the haul road?</code><br />
                then a follow-up like <code>and what about gloves?</code>
            </div>
        }
        @foreach (var m in _messages)
        {
            <div class="row @(m.IsUser ? "user" : "bot")">
                <div>
                    @if (!m.IsUser && m.Rewritten is not null)
                    {
                        <div class="rewrite">interpreted as: "@m.Rewritten"</div>
                    }
                    <div class="bubble">@m.Text@if (m.Streaming)
                        {<span class="caret">&nbsp;</span>}</div>
                    @if (!m.IsUser && m.Sources.Count > 0)
                    {
                        <div class="sources">
                            <span class="lbl">sources</span>
                            <ul>
                                @foreach (var src in m.Sources.Select(s => s.Source).Distinct())
                                {
                                    <li>@src</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="composer">
        <input @bind="_input" @bind:event="oninput" @onkeydown="OnKeyDown"
               placeholder="Ask a question…" disabled="@_busy" />
        <button @onclick="SendAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_input))">Send</button>
        <button class="ghost" @onclick="Clear" disabled="@_busy">Clear</button>
    </div>
</div>

@code {
    private readonly List<Msg> _messages = new();
    private readonly List<ConversationTurn> _history = new();
    private string? _input;
    private bool _busy;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_busy) await SendAsync();
    }

    private async Task SendAsync()
    {
        var question = _input?.Trim();
        if (string.IsNullOrEmpty(question) || _busy) return;

        _input = "";
        _busy = true;
        _messages.Add(new Msg { IsUser = true, Text = question });
        var bot = new Msg { IsUser = false, Streaming = true };
        _messages.Add(bot);
        await Render();

        try
        {
            // Retrieval runs first; sources are shown immediately, then the answer streams in.
            var answer = await Rag.AskStreamingAsync(question, _history);
            bot.Rewritten = answer.RewrittenQuery;
            bot.Sources = answer.Sources;
            await Render();

            await foreach (var token in answer.Tokens)
            {
                bot.Text += token;
                StateHasChanged();
                await Task.Delay(8); // give the renderer a beat — produces the typewriter effect
            }
        }
        catch (Exception ex)
        {
            bot.Text = $"⚠️ {ex.Message}";
        }
        finally
        {
            bot.Streaming = false;
            _history.Add(new ConversationTurn(true, question));
            _history.Add(new ConversationTurn(false, bot.Text));
            if (_history.Count > 8) _history.RemoveRange(0, _history.Count - 8); // bound prompt tokens
            _busy = false;
            await Render();
        }
    }

    private void Clear()
    {
        _messages.Clear();
        _history.Clear();
    }

    private async Task Render()
    {
        StateHasChanged();
        await JS.InvokeVoidAsync("scrollToBottom", "messages");
    }

    private sealed class Msg
    {
        public bool IsUser { get; set; }
        public string Text { get; set; } = "";
        public string? Rewritten { get; set; }
        public IReadOnlyList<KnowledgeChunk> Sources { get; set; } = Array.Empty<KnowledgeChunk>();
        public bool Streaming { get; set; }
    }
}
